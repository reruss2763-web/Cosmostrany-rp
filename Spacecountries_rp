# ========== ЗАПУСК ==========
async def main():
    migrate_db()
    init_db()
    await bot.delete_webhook(drop_pending_updates=True)
    me = await bot.get_me()
    print(f"Bot @{me.username} is up and polling for updates...")
    await dp.start_polling(bot)


if __name__ == "__main__":
    asyncio.run(main())
